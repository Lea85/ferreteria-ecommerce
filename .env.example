# =============================================================================
# SUPABASE - Base de datos PostgreSQL
# =============================================================================
# Ir a: https://supabase.com → tu proyecto → Project Settings → Database
# Copiar "Connection string (URI)" del Connection Pooler modo "Transaction"
# Reemplazar [YOUR-PASSWORD] con la contraseña que elegiste al crear el proyecto
DATABASE_URL="postgresql://postgres.XXXXX:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Para migraciones (conexión directa, no pooler):
# Ir a: Project Settings → Database → Connection string → Direct
DIRECT_URL="postgresql://postgres.XXXXX:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# =============================================================================
# AUTH.JS
# =============================================================================
# Generar con: npx auth secret
AUTH_SECRET="tu-secreto-seguro-aqui"

# Google OAuth (opcional - si no lo configurás, solo funciona login con email/password)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# =============================================================================
# APP
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Solo para desarrollo: bypass de auth en el admin panel
# ADMIN_LAYOUT_BYPASS=1
